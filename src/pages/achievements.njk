---
layout: layouts/base.njk
permalink: achievements.html
activePage: achievements
---
{% set pageData = pages.achievements %}
<main class="page-main">
    <div class="container">
        <header class="page-header panel-header-divider reveal">
            <div>
                <p class="section-label">{{ pageData.hero.kicker }}</p>
                <h1 class="page-title">{{ pageData.hero.title }}</h1>
                <p class="page-copy">{{ pageData.hero.copy }}</p>
            </div>
            <div class="section-index">{{ pageData.hero.index }}</div>
        </header>

        <section class="editorial-grid reveal reveal-delay-1">
            <article class="card surface-low panel-padding-xl grid-span-8 card-relative-clip">
                <div class="section-label">{{ pageData.anchor.kicker }}</div>
                <h2 class="panel-title">{{ pageData.anchor.title }}</h2>
                <p class="panel-copy">{{ pageData.anchor.copy }}</p>
                <div class="stat-row mt-2">
                    {% for metric in pageData.anchor.metrics %}
                    <div class="metric-box">
                        <span class="metric-value">{{ metric.value }}</span>
                        <span class="metric-label">{{ metric.label }}</span>
                    </div>
                    {% endfor %}
                </div>
            </article>
            <aside class="card surface-container panel-padding-lg grid-span-4 text-center">
                <div class="contact-icon centered-icon"><span class="material-symbols-outlined">verified</span></div>
                <h2 class="panel-title">{{ pageData.signal.title }}</h2>
                <p class="panel-copy">{{ pageData.signal.copy }}</p>
                <div class="section-label section-label-top-gap">{{ pageData.signal.meta }}</div>
            </aside>
        </section>

        <section class="detail-grid grid-split-wide mt-2 reveal reveal-delay-2">
            <article class="card surface-lowest panel-padding-xl">
                <h2 class="section-heading">{{ pageData.skills.heading }}</h2>
                <ul class="ledger-list">
                    {% for item in pageData.skills.items %}
                    <li class="ledger-item"><strong>{{ item.label }}</strong><span class="meta-text">{{ item.value }}</span></li>
                    {% endfor %}
                </ul>
            </article>
            <article class="card glass-panel panel-padding-xl">
                <h2 class="section-heading">{{ pageData.sectors.heading }}</h2>
                <div class="tag-row">
                    {% for sector in pageData.sectors.items %}
                    <span class="tag">{{ sector }}</span>
                    {% endfor %}
                </div>
            </article>
        </section>

        <section class="card surface-low panel-padding-xl mt-3 reveal reveal-delay-3">
            <h2 class="section-heading">{{ pageData.systems.heading }}</h2>
            <p class="page-copy copy-wide mb-2">{{ pageData.systems.copy }}</p>
            <div class="project-list">
                {% for item in pageData.systems.projects %}
                <article class="project-card">
                    <h3 class="project-title">{{ item.title }}</h3>
                    <p class="panel-copy">{{ item.copy }}</p>
                </article>
                {% endfor %}
            </div>
        </section>

        <section class="cta-panel reveal reveal-delay-4">
            <div>
                <h2 class="cta-title">{{ pageData.cta.title }}</h2>
                <p class="panel-copy">{{ pageData.cta.copy }}</p>
            </div>
            <div class="link-row">
                <a class="button-primary" href="{{ profile.links.contact }}">{{ pageData.cta.primary }}</a>
                <a class="button-secondary" href="{{ profile.links.contact }}">{{ pageData.cta.secondary }}</a>
            </div>
        </section>
    </div>
</main>
