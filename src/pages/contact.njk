---
layout: layouts/base.njk
permalink: contact.html
activePage: contact
---
{% set pageData = pages.contact %}
<main class="page-main">
    <div class="container">
        <header class="page-header reveal">
            <div>
                <p class="section-label">{{ pageData.hero.kicker }}</p>
                <h1 class="page-title">{{ pageData.hero.title }}</h1>
                <p class="page-copy">{{ pageData.hero.copy }}</p>
            </div>
            <div class="section-index">{{ pageData.hero.index }}</div>
        </header>

        <section class="contact-grid reveal reveal-delay-1">
            <article class="form-card">
                <div>
                    <p class="section-label">{{ pageData.form.kicker }}</p>
                    <h2 class="section-heading">{{ pageData.form.heading }}</h2>
                    <p class="panel-copy">{{ pageData.form.copy }}</p>
                </div>
                <div class="ledger-list mt-2">
                    {% for point in pageData.form.points %}
                    <div class="ledger-item">
                        <strong>{{ point.label }}</strong>
                        <span class="meta-text">{{ point.value }}</span>
                    </div>
                    {% endfor %}
                </div>
                <div class="link-row mt-2">
                    <a class="button-primary" href="{{ profile.links.emailHref }}">{{ pageData.form.primary }}</a>
                    <a class="button-secondary" href="{{ profile.links.phoneHref }}">{{ pageData.form.secondary }}</a>
                </div>
            </article>

            <aside class="sidebar-stack">
                <section class="card surface-highest panel-padding-xl reveal reveal-delay-2">
                    <p class="section-label">{{ pageData.direct.kicker }}</p>
                    <div class="contact-link-card">
                        <div class="contact-icon"><span class="material-symbols-outlined">mail</span></div>
                        <div>
                            <div class="contact-title">{{ pageData.direct.email.label }}</div>
                            <a class="panel-copy" href="{{ profile.links.emailHref }}">{{ profile.contact.email }}</a>
                        </div>
                    </div>
                    <div class="contact-link-card">
                        <div class="contact-icon"><span class="material-symbols-outlined">call</span></div>
                        <div>
                            <div class="contact-title">{{ pageData.direct.phone.label }}</div>
                            <a class="panel-copy" href="{{ profile.links.phoneHref }}">{{ profile.contact.phone }}</a>
                        </div>
                    </div>
                    <div class="contact-link-card">
                        <div class="contact-icon"><span class="material-symbols-outlined">public</span></div>
                        <div>
                            <div class="contact-title">{{ profile.social.linkedin.label }}</div>
                            <a aria-label="{{ profile.social.linkedin.ariaLabel }}" class="panel-copy" href="{{ profile.social.linkedin.href }}" rel="noreferrer" target="_blank">{{ profile.social.linkedin.href }}</a>
                        </div>
                    </div>
                    <div class="contact-link-card">
                        <div class="contact-icon"><span class="material-symbols-outlined">code</span></div>
                        <div>
                            <div class="contact-title">{{ profile.social.github.label }}</div>
                            <a aria-label="{{ profile.social.github.ariaLabel }}" class="panel-copy" href="{{ profile.social.github.href }}" rel="noreferrer" target="_blank">{{ profile.social.github.href }}</a>
                        </div>
                    </div>
                </section>

                <section class="card surface-low panel-padding-lg reveal reveal-delay-3">
                    <h2 class="panel-title">{{ pageData.services.heading }}</h2>
                    <div class="tag-row">
                        {% for item in pageData.services.items %}
                        <span class="tag">{{ item }}</span>
                        {% endfor %}
                    </div>
                </section>

                <section class="card surface-lowest panel-padding-lg reveal reveal-delay-4">
                    <h2 class="panel-title">{{ pageData.note.heading }}</h2>
                    <p class="panel-copy">{{ pageData.note.copy }}</p>
                </section>
            </aside>
        </section>
    </div>
</main>
