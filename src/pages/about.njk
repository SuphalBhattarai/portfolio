---
layout: layouts/base.njk
permalink: about.html
activePage: about
---
{% set pageData = pages.about %}
<main class="page-main">
    <div class="container">
        <header class="page-header reveal">
            <div>
                <p class="section-label">{{ pageData.hero.kicker }}</p>
                <h1 class="page-title">{{ pageData.hero.title }}</h1>
                <p class="page-copy">{{ pageData.hero.copy }}</p>
            </div>
            <div class="section-index">{{ pageData.hero.index }}</div>
        </header>

        <section aria-label="About overview" class="editorial-grid reveal reveal-delay-1">
            <article class="card surface-low panel-padding-xl grid-span-7">
                <span aria-hidden="true" class="material-symbols-outlined panel-icon">analytics</span>
                <h2 class="panel-title">{{ pageData.overview.primary.title }}</h2>
                <p class="panel-copy">{{ pageData.overview.primary.copy }}</p>
            </article>

            <aside class="home-overview-image">
                <div class="hero-image-frame">
                    <img alt="{{ profile.site.portrait.alt }}" class="hero-image" src="{{ profile.site.portrait.src }}">
                </div>
            </aside>
        </section>

        <section class="detail-grid grid-three-equal mt-2 reveal reveal-delay-2">
            {% for pillar in pageData.pillars %}
            <article class="card {% if loop.index == 1 %}surface-high{% elseif loop.index == 2 %}surface-container{% else %}surface-highest{% endif %} panel-padding-lg">
                <span aria-hidden="true" class="material-symbols-outlined panel-icon">{% if loop.index == 1 %}domain{% elseif loop.index == 2 %}fact_check{% else %}terminal{% endif %}</span>
                <h3 class="panel-title">{{ pillar.title }}</h3>
                <p class="panel-copy">{{ pillar.copy }}</p>
            </article>
            {% endfor %}
        </section>

        <section class="mt-5 reveal reveal-delay-3">
            <h2 class="section-heading">{{ pageData.timeline.heading }}</h2>
            <div class="timeline">
                {% for item in [pageData.timeline[0], pageData.timeline[1], pageData.timeline[2]] %}
                <article class="timeline-item">
                    <div class="timeline-marker"><span class="material-symbols-outlined">{% if loop.index == 1 %}query_stats{% elseif loop.index == 2 %}account_balance{% else %}deployed_code{% endif %}</span></div>
                    <div>
                        <div class="timeline-meta">{{ item.period }}</div>
                        <span class="timeline-role">{{ item.role }}</span>
                    </div>
                    <div class="timeline-card">
                        <h3 class="timeline-title">{{ item.title }}</h3>
                        <p class="timeline-copy">{{ item.copy }}</p>
                    </div>
                </article>
                {% endfor %}
            </div>
        </section>

        <section class="card surface-lowest panel-padding-xl mt-5 reveal reveal-delay-4">
            <h2 class="section-heading">{{ pageData.toolkit.heading }}</h2>
            <div class="ledger-columns">
                {% for column in pageData.toolkit.columns %}
                <div>
                    <h3 class="ledger-title">{{ column.title }}</h3>
                    <ul class="ledger-list">
                        {% for item in column.items %}
                        <li class="ledger-item"><strong>{{ item.label }}</strong><span class="meta-text">{{ item.value }}</span></li>
                        {% endfor %}
                    </ul>
                </div>
                {% endfor %}
            </div>
        </section>

        <section class="cta-panel reveal reveal-delay-5">
            <div>
                <h2 class="cta-title">{{ pageData.cta.title }}</h2>
                <p class="panel-copy">{{ pageData.cta.copy }}</p>
            </div>
            <div class="link-row">
                <a class="button-primary" href="{{ profile.links.contact }}">{{ pageData.cta.primary }}</a>
                <a class="button-secondary" href="{{ profile.links.cv }}">{{ pageData.cta.secondary }}</a>
            </div>
        </section>
    </div>
</main>
