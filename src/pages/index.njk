---
layout: layouts/base.njk
permalink: index.html
activePage: home
---
{% set pageData = pages.home %}
<main>
    <section class="hero" id="home">
        <div class="container">
            <div class="hero-grid">
                <div>
                    <div class="status-pill reveal">
                        <span class="status-pill-dot"></span>
                        <span>{{ pageData.hero.status }}</span>
                    </div>
                    <h1 class="hero-title">
                        <span>{{ pageData.hero.titleLineOne }}</span>
                        <span class="hero-title-accent">{{ pageData.hero.titleLineTwo }}</span>
                    </h1>
                    <p class="hero-subtitle">{{ pageData.hero.subtitle }}</p>
                    <p class="hero-copy">{{ pageData.hero.copy }}</p>
                    <div class="hero-actions">
                        <a class="button-primary" href="{{ profile.links.cv }}">{{ pageData.hero.primaryCta }}</a>
                    </div>
                </div>

                <div class="hero-visual">
                    <div class="hero-image-frame">
                        <img alt="{{ profile.site.portrait.alt }}" class="hero-image" src="{{ profile.site.portrait.src }}">
                    </div>
                    <aside aria-label="Academic focus" class="focus-card reveal">
                        <p class="focus-label">{{ pageData.focus.label }}</p>
                        <p class="focus-title">{{ pageData.focus.title }}</p>
                        <p class="panel-copy focus-summary-copy">{{ profile.recruiter.summary }}</p>
                        <div class="focus-metrics">
                            <div>
                                <span class="focus-value" data-experience-metric>0.0</span>
                                <span>{{ pageData.focus.metricLabel }}</span>
                            </div>
                            <div>
                                <span class="focus-value">{{ profile.proof.sectorsCount }}</span>
                                <span>{{ pageData.focus.metricLabelAlt }}</span>
                            </div>
                        </div>
                    </aside>
                </div>
            </div>
        </div>
    </section>

    <section aria-label="Recruiter proof strip" class="proof-strip reveal">
        <div class="container">
            <div class="proof-strip-grid">
                {% for item in profile.recruiter.proofStrip %}
                <article class="proof-pill">
                    <span class="proof-pill-index">0{{ loop.index }}</span>
                    <span class="proof-pill-text">{{ item }}</span>
                </article>
                {% endfor %}
            </div>
        </div>
    </section>

    <section class="page-main">
        <div class="container">
            <section class="detail-grid grid-three-equal reveal">
                <div class="section-head section-head-compact section-head-full">
                    <div>
                        <h2 class="section-title section-title-dark">{{ pageData.whyHire.heading }}</h2>
                        <p class="section-copy section-copy-dark">{{ profile.recruiter.summary }}</p>
                    </div>
                    <div class="section-index section-index-dark">{{ pageData.whyHire.index }}</div>
                </div>
                {% for item in profile.recruiter.whyHire %}
                <article class="card surface-low panel-padding-lg">
                    <h3 class="panel-title">{{ item.title }}</h3>
                    <p class="panel-copy">{{ item.copy }}</p>
                </article>
                {% endfor %}
            </section>
        </div>
    </section>

    <section class="section-dark reveal" id="expertise">
        <div class="container">
            <div class="section-head">
                <div>
                    <h2 class="section-title">{{ pageData.expertise.heading }}</h2>
                    <p class="section-copy">{{ pageData.expertise.copy }}</p>
                </div>
                <div class="section-index">{{ pageData.expertise.index }}</div>
            </div>

            <div class="expertise-grid">
                {% for card in pageData.cards %}
                <article class="expertise-card">
                    <span aria-hidden="true" class="material-symbols-outlined">{% if loop.index == 1 %}payments{% elseif loop.index == 2 %}fact_check{% elseif loop.index == 3 %}account_balance{% else %}terminal{% endif %}</span>
                    <h3 class="expertise-title">{{ card.title }}</h3>
                    <p class="expertise-copy">{{ card.copy }}</p>
                </article>
                {% endfor %}
            </div>
        </div>
    </section>
</main>
